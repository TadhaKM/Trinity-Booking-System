// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String
  password         String   @default("")
  isOrganiser      Boolean  @default(false)
  isAdmin          Boolean  @default(false)
  isBanned         Boolean  @default(false)
  profilePicture   String?
  stripeConnectId  String?
  payoutsEnabled   Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  orders            Order[]
  following         SocietyFollower[]
  postLikes         PostLike[]
  notifications     Notification[]
  waitlistEntries   WaitlistEntry[]
  savedEvents       SavedEvent[]
  comments          EventComment[]
  refundRequests    RefundRequest[]
  pushSubscriptions PushSubscription[]
}

model Society {
  id          String   @id @default(cuid())
  name        String
  description String
  category    String
  imageUrl    String
  location    String   // JSON string: { lat, lng }
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events    Event[]
  followers SocietyFollower[]
  posts     SocietyPost[]
}

model SocietyFollower {
  id        String   @id @default(cuid())
  userId    String
  societyId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  society Society @relation(fields: [societyId], references: [id], onDelete: Cascade)

  @@unique([userId, societyId])
}

model Event {
  id             String   @id @default(cuid())
  societyId      String
  title          String
  description    String
  startDate      DateTime
  endDate        DateTime
  location       String
  locationCoords String   // JSON string: { lat, lng }
  category       String
  imageUrl       String
  galleryImages  String?  // JSON array of additional image URLs
  tags           String   // JSON string: string[]
  organiserId    String
  policy         String?  // Refund/transfer policy text
  faqJson        String?  // JSON string: [{q, a}]
  venueCapacity  Int?     // Maximum attendees across all ticket types
  isPublished    Boolean  @default(true)
  isCancelled    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  society         Society         @relation(fields: [societyId], references: [id], onDelete: Cascade)
  ticketTypes     TicketType[]
  orders          Order[]
  societyPosts    SocietyPost[]
  waitlistEntries WaitlistEntry[]
  savedBy         SavedEvent[]
  checkInLogs     CheckInLog[]
  comments        EventComment[]
}

model TicketType {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  price     Float
  quantity  Int
  available Int
  createdAt DateTime @default(now())

  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tickets         Ticket[]
  waitlistEntries WaitlistEntry[]
}

model Coupon {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Int
  expiresAt       DateTime
  maxUses         Int
  usedCount       Int      @default(0)
  createdAt       DateTime @default(now())
}

model Order {
  id                    String    @id @default(cuid())
  userId                String
  eventId               String
  totalAmount           Float
  status                String    @default("CONFIRMED") // CONFIRMED | CANCELLED | REFUNDED | PARTIALLY_REFUNDED
  stripePaymentIntentId String?
  createdAt             DateTime  @default(now())

  user           User            @relation(fields: [userId], references: [id])
  event          Event           @relation(fields: [eventId], references: [id])
  tickets        Ticket[]
  refundRequests RefundRequest[]
}

model Ticket {
  id           String    @id @default(cuid())
  orderId      String
  ticketTypeId String
  price        Float
  qrCode       String    @unique
  checkedInAt  DateTime?
  isRefunded   Boolean   @default(false)
  refundedAt   DateTime?
  createdAt    DateTime  @default(now())

  order          Order          @relation(fields: [orderId], references: [id])
  ticketType     TicketType     @relation(fields: [ticketTypeId], references: [id])
  checkInLog     CheckInLog?
  refundRequest  RefundRequest?
}

model SocietyPost {
  id        String   @id @default(cuid())
  societyId String
  eventId   String?
  imageUrl  String   // base64 data URI or URL
  caption   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  society Society    @relation(fields: [societyId], references: [id], onDelete: Cascade)
  event   Event?     @relation(fields: [eventId], references: [id], onDelete: SetNull)
  likes   PostLike[]
}

// ── Stripe Connect Demo ──────────────────────────────────────────────────────
model ConnectDemoAccount {
  id              String   @id @default(cuid())
  stripeAccountId String   @unique
  displayName     String
  email           String
  createdAt       DateTime @default(now())
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  post SocietyPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

// ── Phase 1 models ───────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // BOOKING_CONFIRMED | TICKET_RECEIVED | EVENT_REMINDER | NEW_EVENT | EVENT_UPDATED | EVENT_CANCELLED | WAITLIST_PROMOTED | LOW_AVAILABILITY | REFUND_PROCESSED
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WaitlistEntry {
  id           String   @id @default(cuid())
  userId       String
  ticketTypeId String
  eventId      String
  position     Int
  notified     Boolean  @default(false)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  ticketType TicketType @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, ticketTypeId])
}

model SavedEvent {
  id        String   @id @default(cuid())
  userId    String
  eventId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

model CheckInLog {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  eventId   String
  scannedBy String   // organiserId
  scannedAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id])
  event  Event  @relation(fields: [eventId], references: [id])
}

// ── Phase 2 models ───────────────────────────────────────────────────────────

model RefundRequest {
  id             String    @id @default(cuid())
  orderId        String
  ticketId       String?   @unique // null = full order refund, set = single-ticket refund
  userId         String
  reason         String
  status         String    @default("PENDING") // PENDING | APPROVED | REJECTED | PROCESSED
  amount         Float     // requested refund amount
  stripeRefundId String?
  reviewedBy     String?   // adminId
  reviewNote     String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order  Order   @relation(fields: [orderId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])
  user   User    @relation(fields: [userId], references: [id])
}

model EventComment {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  parentId  String?  // null = top-level, set = reply
  body      String
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event   Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent  EventComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies EventComment[] @relation("CommentReplies")
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String   // userId who performed the action
  action     String   // BAN_USER | UNBAN_USER | DELETE_EVENT | HIDE_COMMENT | APPROVE_REFUND | REJECT_REFUND | PROCESS_REFUND
  entityType String   // user | event | comment | refund | order
  entityId   String
  details    String?  // JSON: extra context
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
